{
  "lsp": {
    "deno": {
      "settings": {
        "deno": {
          "enable": false
        }
      }
    }
  },
  "languages": {
    "JavaScript": {
      "language_servers": ["!deno", "..."],
      "formatter": "language_server"
    },
    "TypeScript": {
      "language_servers": ["!deno", "angular", "..."],
      "formatter": "language_server"
    },
    "HTML": {
      "language_servers": ["angular", "..."]
    }
  }
}
