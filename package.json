{
  "name": "kassette",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "ng": "ng",
    "dev": "ng serve",
    "dev:no-mocks": "ng serve -c no-mocks",
    "build": "ng build -c production && node -e \"const fs=require('fs'),p=require('path'),d='dist/browser';fs.readdirSync(d).filter(f=>/\\.(js|css)$/.test(f)).forEach(f=>fs.renameSync(p.join(d,f),p.join(d,'assets',f)))\"",
    "test": "ng test --no-watch",
    "test:coverage": "ng test --no-watch --coverage",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "release:tag": "git tag -s v$(node -p \"require('./package.json').version\") -m \"Release v$(node -p \"require('./package.json').version\")\"",
    "prepare": "command -v git >/dev/null 2>&1 && lefthook install || true"
  },
  "dependencies": {
    "@angular/animations": "^21.2.8",
    "@angular/cdk": "^21.2.6",
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/platform-browser": "^21.2.8",
    "@angular/platform-browser-dynamic": "^21.2.8",
    "@angular/router": "^21.2.8",
    "@coinbase/wallet-sdk": "^4.3.7",
    "@metamask/sdk": "^0.34.0",
    "@reown/appkit": "^1.8.19",
    "@reown/appkit-adapter-wagmi": "^1.8.19",
    "@safe-global/safe-apps-provider": "^0.18.6",
    "@safe-global/safe-apps-sdk": "^9.1.0",
    "@wagmi/core": "^3.4.0",
    "@walletconnect/ethereum-provider": "^2.23.6",
    "porto": "^0.2.37",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.0",
    "viem": "^2.46.3"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.6.0",
    "lefthook": "^2.1.5",
    "msw": "^2.12.10",
    "postcss": "^8.5.6",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "pnpm": {
    "overrides": {
      "axios@<1.15.0": ">=1.15.0",
      "socket.io-parser@<4.2.6": ">=4.2.6",
      "minimatch@<10.2.3": ">=10.2.3",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4 <4.0.4": ">=4.0.4",
      "brace-expansion@<5.0.5": ">=5.0.5",
      "hono@<4.12.12": ">=4.12.12",
      "@hono/node-server@<1.19.13": ">=1.19.13",
      "vite@<7.3.2": ">=7.3.2",
      "undici@<7.24.0": ">=7.24.0",
      "tar@<7.5.11": ">=7.5.11",
      "path-to-regexp@<8.4.0": ">=8.4.0",
      "defu@<6.1.5": ">=6.1.5",
      "h3@<1.15.9": ">=1.15.9",
      "immutable@<5.1.5": ">=5.1.5",
      "express-rate-limit@<8.2.2": ">=8.2.2"
    }
  }
}
