{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "kassette": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "kp",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": ["src/styles/font.css", "src/styles/tailwind.css"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2MB",
                  "maximumError": "5MB"
                }
              ],
              "outputHashing": "all",
              "baseHref": "/public/",
              "deployUrl": "assets/",
              "assets": [
                {
                  "glob": "**/*",
                  "input": "public",
                  "output": "assets"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "e2e": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2MB",
                  "maximumError": "5MB"
                }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.e2e.ts"
                }
              ]
            },
            "no-mocks": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.no-mocks.ts"
                }
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "buildTarget": "kassette:build:development",
            "runner": "vitest",
            "tsConfig": "tsconfig.spec.json",
            "include": ["src/**/*.spec.ts"],
            "setupFiles": ["src/app/testing/vitest-setup.ts"],
            "providersFile": "src/app/testing/test-providers.ts",
            "coverage": true,
            "coverageReporters": ["text", "json-summary", "json", "lcov", "html"],
            "coverageThresholds": {
              "statements": 34,
              "branches": 30,
              "functions": 25,
              "lines": 35
            }
          }
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "kassette:build:production"
            },
            "development": {
              "buildTarget": "kassette:build:development"
            },
            "no-mocks": {
              "buildTarget": "kassette:build:no-mocks"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "port": 3001,
            "host": "127.0.0.1",
            "proxyConfig": "proxy.conf.json"
          }
        }
      }
    }
  },
  "cli": {
    "packageManager": "pnpm",
    "analytics": false
  }
}
